# AimiliVPN server environment example.
# Copy to /etc/default/aimilivpn and restart the service.

# gateway: single local proxy tunnel
# pool: multi-port proxy pool
SERVICE_MODE=gateway

UI_HOST=::
UI_PORT=8787

# Gateway mode proxy. Keep 127.0.0.1 unless you intentionally expose it.
LOCAL_PROXY_HOST=127.0.0.1
LOCAL_PROXY_PORT=7928

# Pool mode. Required when SERVICE_MODE=pool.
POOL_SIZE=50
POOL_PORT_BASE=52000
POOL_PUBLIC_HOST=YOUR_VPS_PUBLIC_IP_OR_DOMAIN
POOL_LISTEN_HOST=0.0.0.0
POOL_MAX_STARTING=5
POOL_SLOT_START_TIMEOUT=90
POOL_API_RETURN_CREDENTIALS=true

# Optional fixed credentials. If unset, pool mode generates them in
# vpngate_data/pool_secrets.json on first start.
# POOL_API_TOKEN=
# POOL_PROXY_USER=
# POOL_PROXY_PASS=
