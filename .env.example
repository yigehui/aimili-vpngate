# AimiliVPN runtime config example.
# Copy this file to .env on the server and restart the service.

# gateway: single VPN tunnel + one HTTP/SOCKS5 proxy
# pool: multiple VPN tunnels + fixed proxy ports
SERVICE_MODE=gateway

# Web UI
UI_HOST=::
UI_PORT=8787

# Gateway mode proxy. Keep 127.0.0.1 unless you want to expose it.
LOCAL_PROXY_HOST=127.0.0.1
LOCAL_PROXY_PORT=7928

# Common runtime tuning
FETCH_INTERVAL_SECONDS=1260
CHECK_INTERVAL_SECONDS=1260
TARGET_VALID_NODES=3
OPENVPN_TEST_TIMEOUT_SECONDS=35

# Upstream proxy for fetching VPNGate API / TCP OpenVPN when needed.
# UPSTREAM_PROXY_TYPE=http
# UPSTREAM_PROXY_HOST=127.0.0.1
# UPSTREAM_PROXY_PORT=7890
# UPSTREAM_PROXY_USER=
# UPSTREAM_PROXY_PASS=

# Proxy pool mode. Required when SERVICE_MODE=pool.
POOL_SIZE=50
POOL_PORT_BASE=52000
POOL_PUBLIC_HOST=YOUR_VPS_PUBLIC_IP_OR_DOMAIN
POOL_LISTEN_HOST=0.0.0.0
POOL_MAX_STARTING=5
POOL_SLOT_START_TIMEOUT=90
# true means pool list/random only exposes ports after health check confirms the real exit IP.
POOL_REQUIRE_EXIT_IP=true
POOL_API_RETURN_CREDENTIALS=true

# Proxy pool API token and proxy credentials.
# If empty, first pool startup generates and stores them in vpngate_data/pool_secrets.json.
# These values are the HTTP/SOCKS5 proxy username/password returned by /api/pool/proxies.
# POOL_API_TOKEN=
# POOL_PROXY_USER=
# POOL_PROXY_PASS=
